# === REQUIRED ===
JWT_SECRET=change_me_to_a_random_64_char_string
MONGODB_URI=mongodb://mongodb:27017/oriveo

# === SECURITY ===
PHI_ENCRYPTION_KEY=change_me_to_64_hex_chars
JWT_EXPIRES_IN=7d
CORS_ORIGIN=https://yourdomain.com
NODE_ENV=production

# === OPTIONAL SERVICES ===
REDIS_URL=redis://redis:6379
PRACTICE_NAME=Your Clinic Name
PRACTICE_WEBSITE_URL=https://yourclinic.com
PORT=5000
LOG_LEVEL=info
RATE_LIMIT_MAX=100
WEB_CONCURRENCY=4

# === STRIPE BILLING ===
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# === SENTRY ===
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# === SSL (for local dev without Docker) ===
SSL_CERT_PATH=
SSL_KEY_PATH=

# === PROVIDERS — configure via Clinic Settings UI ===
